{
  "name": "@kubevious/helpers",
  "version": "1.0.70",
  "description": "Kubevious Helpers",
  "main": "dist/index.js",
  "types": "dist",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "test": "env TS_NODE_COMPILER_OPTIONS='{\"module\": \"commonjs\" }' mocha -r ts-node/register 'test/**/*.ts'",
    "build": "tsc",
    "format": "prettier --write ./src/ ./test/",
    "format-check": "prettier --write ./src/ ./test/",
    "lint": "eslint"
  },
  "author": "Ruben Hakopian <ruben.hakopian@gmail.com>",
  "license": "Apache-2.0",
  "dependencies": {
    "moment": "^2.30.1",
    "the-lodash": "^2.1.2",
    "the-logger": "^2.1.1",
    "the-promise": "^2.1.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "mocha": "^11.7.6",
    "prettier": "^2.8.8",
    "should": "^13.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "the-lodash": "^2.1.2",
      "the-logger": "^2.1.1",
      "the-promise": "^2.1.3"
    }
  }
}
